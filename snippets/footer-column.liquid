<div>
  <h3 class="text-sm font-semibold text-primary tracking-wide mb-5 {{ class }}">
    {{ heading }}
  </h3>
  <ul class="{{ spacing }}">
    {% for link in linklists[menu].links %}
      <li>
        <a
          href="{{ link.url }}"
          class="text-[16px] text-secondary hover:text-primary transition-colors duration-200 leading-snug maison-book"
        >
          {{ link.title }}
        </a>
      </li>
    {% endfor %}
  </ul>
</div>
