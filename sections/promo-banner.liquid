<div class="pb-section">
  <div class="pb-grid">
    {% for block in section.blocks %}
      {% if block.type == 'banner_card' %}
        <a href="{{ block.settings.link }}" class="pb-card" {{ block.shopify_attributes }}>
          <div class="pb-card-media">
            {% if block.settings.image != blank %}
              {{
                block.settings.image
                | image_url: width: 1200
                | image_tag:
                  class: 'pb-card-img',
                  loading: 'lazy',
                  alt: block.settings.title,
                  widths: '400, 600, 800, 1000, 1200'
              }}
            {% else %}
              <div class="pb-card-placeholder">
                {{ 'collection-2' | placeholder_svg_tag: 'pb-placeholder-svg' }}
              </div>
            {% endif %}
            <div class="pb-card-scrim"></div>
          </div>

          <div class="pb-card-content">
            {% if block.settings.title != blank %}
              <h3 class="pb-card-title maison-book">{{ block.settings.title }}</h3>
            {% endif %}
            {% if block.settings.cta_text != blank %}
              <span class="pb-card-cta maison-book">{{ block.settings.cta_text }}</span>
            {% endif %}
          </div>
        </a>
      {% endif %}
    {% endfor %}
  </div>
</div>

<style>
  .pb-section {
    width: 100%;
  }

  .pb-grid {
    display: grid;
    grid-template-columns: 1fr;
    grid-template-rows: repeat(3, calc(100svh / 3));
    max-height: 100svh;
  }

  .pb-card {
    position: relative;
    display: block;
    overflow: hidden;
    text-decoration: none;
    width: 100%;
    height: 100%;
  }

  .pb-card-media {
    position: absolute;
    inset: 0;
  }

  .pb-card-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    display: block;
    transition: transform 0.6s ease;
  }

  .pb-card:hover .pb-card-img {
    transform: scale(1.04);
  }

  .pb-card-placeholder {
    width: 100%;
    height: 100%;
    background: #374151;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .pb-placeholder-svg {
    width: 40%;
    height: 40%;
    opacity: 0.2;
  }

  .pb-card-scrim {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(0, 0, 0, 0.72) 0%,
      rgba(0, 0, 0, 0.5) 25%,
      rgba(0, 0, 0, 0.2) 55%,
      transparent 80%
    );
  }

  .pb-card-content {
    position: absolute;
    bottom: 20%;
    left: 0;
    right: 0;
    padding: 20px 16px 24px;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 12px;
  }

  .pb-card-title {
    color: #fff;
    font-size: clamp(18px, 3.5vw, 36px);
    font-weight: 400;
    letter-spacing: 0.2px;
    line-height: 1.15;
    margin: 0;
  }

  .pb-card-cta {
    display: inline-block;
    background: #fff;
    color: #111;
    font-size: 14px;
    letter-spacing: 1.4px;
    text-transform: uppercase;
    padding: 12px 20px;
    white-space: nowrap;
    transition: background 0.2s ease, color 0.2s ease;
  }

  .pb-card:hover .pb-card-cta {
    background: #111;
    color: #fff;
  }

  @media (min-width: 768px) {
    .pb-grid {
      grid-template-columns: repeat(3, 1fr);
      grid-template-rows: 1fr;
      height: 100svh;
      max-height: 100svh;
    }

    .pb-card-content {
      padding: 28px 20px 36px;
      bottom: 50%;
      gap: 18px;
    }

    .pb-card-title {
      font-size: clamp(20px, 2vw, 40px);
    }

    .pb-card-cta {
      padding: 12px 24px;
    }
  }

  @media (min-width: 1024px) {
    .pb-card-content {
      padding: 36px 28px 44px;
      gap: 20px;
      bottom: 45%;
    }

    .pb-grid {
      margin-inline: 42px;
      gap: 12px;
    }
  }
</style>

{% schema %}
{
  "name": "Promo Banner",
  "tag": "section",
  "class": "promo-banner-section",
  "limit": 1,
  "max_blocks": 6,
  "settings": [],
  "blocks": [
    {
      "type": "banner_card",
      "name": "Banner Card",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Background Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "New Arrivals"
        },
        {
          "type": "text",
          "id": "cta_text",
          "label": "Button Text",
          "default": "Shop Now"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link URL"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Promo Banner",
      "category": "Everlane",
      "blocks": [
        {
          "type": "banner_card",
          "settings": {
            "title": "New Arrivals",
            "cta_text": "Shop the Latest"
          }
        },
        {
          "type": "banner_card",
          "settings": {
            "title": "Best-Sellers",
            "cta_text": "Shop Your Favorites"
          }
        },
        {
          "type": "banner_card",
          "settings": {
            "title": "The Holiday Outfit",
            "cta_text": "Shop Occasion"
          }
        }
      ]
    }
  ]
}
{% endschema %}
