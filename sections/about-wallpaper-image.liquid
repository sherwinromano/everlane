<div class="wp-section" id="wp-{{ section.id }}">
  {% if section.settings.image != blank %}
    {{
      section.settings.image
      | image_url: width: 2400
      | image_tag:
        class: 'wp-img',
        loading: 'eager',
        fetchpriority: 'high',
        alt: section.settings.image.alt,
        widths: '600, 900, 1200, 1600, 2000, 2400',
        sizes: '100vw'
    }}
  {% else %}
    <div class="wp-placeholder">
      {{ 'lifestyle-1' | placeholder_svg_tag: 'wp-placeholder-svg' }}
    </div>
  {% endif %}
</div>

<style>
  .wp-section {
    position: relative;
    width: 100%;
    height: 50vh;
    overflow: hidden;
  }

  .wp-img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .wp-placeholder {
    width: 100%;
    height: 100%;
    background: #e5e7eb;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .wp-placeholder-svg {
    width: 15%;
    height: 15%;
    opacity: 0.15;
  }

  @media (min-width: 768px) {
    .wp-section {
      height: 70vh;
    }
  }
</style>

{% schema %}
{
  "name": "Wallpaper Image",
  "tag": "section",
  "class": "wallpaper-section",
  "limit": 2,
  "settings": [
    {
      "type": "header",
      "content": "Image"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Wallpaper Image",
      "info": "Recommended size: 2400 x 1600px or larger for best quality."
    }
  ],
  "presets": [
    {
      "name": "Wallpaper Image",
      "category": "Everlane About Page"
    }
  ]
}
{% endschema %}
