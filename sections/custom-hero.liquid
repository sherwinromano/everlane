{% liquid
  assign hero_image = section.settings.image

  case section.settings.content_alignment
    when 'left'
      assign content_alignment = 'justify-start text-left'
    when 'center'
      assign content_alignment = 'justify-center text-center'
    when 'right'
      assign content_alignment = 'justify-end text-right'
  endcase
%}

<section class="flex h-screen">
  <div class="hero-container flex w-full relative">
    {% if hero_image != blank %}
      {{
        hero_image
        | image_url: width: 2400
        | image_tag:
          loading: 'lazy',
          widths: '768, 1024, 1440, 1800, 2400',
          class: 'absolute inset-0 h-full w-full object-cover'
      }}
    {% else %}
      <img
        src="{{ 'hero-image.webp' | asset_url }}"
        alt="Hero banner"
        class="absolute inset-0 h-full w-full object-cover"
        loading="lazy"
        width="1920"
        height="1080"
      >
    {% endif %}
    {% if section.settings.enable_overlay %}
      <div
        class="overlay-element absolute inset-0 bg-black"
        style="opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};"
      >
        overlay
      </div>
    {% endif %}
    <div class="flex w-full {{ content_alignment }} relative">
      <div class="flex max-w-full flex-col justify-center px-10 md:px-20">
        {% if section.settings.heading != blank %}
          <h1 class="text-white! maison-book tracking-[-0.03em] lg:text-9xl">
            {{ section.settings.heading }}
          </h1>
        {% endif %}

        {% if section.settings.subheading != blank %}
          <div class="subheading mt-6 max-w-120 maison-book text-white">
            {{ section.settings.subheading }}
          </div>
        {% endif %}

        {% if section.settings.button_label != blank %}
          <div class="mt-10">
            <a
              href="{{ section.settings.button_link }}"
              class="
                inline-flex
                items-center
                justify-center
                border
                border-white
                bg-white
                px-20
                py-3
                text-[14px]!
                font-medium
                uppercase
                tracking-[1.4px]
                text-black
                transition
                duration-300
                hover:bg-transparent
                hover:text-white
                maison-book
              "
            >
              {{ section.settings.button_label }}
            </a>
          </div>
        {% endif %}
      </div>
    </div>
  </div>
</section>

<style>
  h1 {
    font-size: 3rem;
  }

  .subheading {
    font-size: 24px;
  }
</style>
{% schema %}
{
  "name": "Custom Hero",
  "limit": 1,
  "settings": [
    {
      "type": "header",
      "content": "Hero heading"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Your Cozy Era"
    },
    {
      "type": "header",
      "content": "Hero subheading"
    },
    {
      "type": "richtext",
      "id": "subheading",
      "label": "Subheading",
      "default": "<p>Get peak comfy-chic with new winter essentials.</p>"
    },
    {
      "type": "header",
      "content": "Hero button"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "header",
      "content": "Content alignment"
    },
    {
      "type": "select",
      "id": "content_alignment",
      "label": "Text placement",
      "default": "left",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ]
    },
    {
      "type": "header",
      "content": "Hero image"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Hero image"
    },
    {
      "type": "header",
      "content": "Hero overlay"
    },
    {
      "type": "checkbox",
      "id": "enable_overlay",
      "label": "Enable overlay",
      "default": true
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 35
    }
  ],
  "presets": [
    {
      "name": "Hero",
      "category": "Everlane"
    }
  ]
}
{% endschema %}
