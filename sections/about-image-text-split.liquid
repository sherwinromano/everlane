{%- assign img_side = section.settings.image_alignment | default: 'left' -%}

<div
  class="si-section"
  id="si-{{ section.id }}"
  data-img-side="{{ img_side }}"
>
  {%- comment -%} ── Image panel ── {%- endcomment -%}
  <div class="si-image-panel" style="background: {{ section.settings.text_bg_color }};">
    {% if section.settings.image != blank %}
      {{
        section.settings.image
        | image_url: width: 1600
        | image_tag:
          class: 'si-img',
          loading: 'lazy',
          alt: section.settings.heading,
          widths: '600, 900, 1200, 1600',
          sizes: '(min-width: 768px) 52vw, 100vw'
      }}
    {% else %}
      <div class="si-img-placeholder">
        {{ 'lifestyle-1' | placeholder_svg_tag: 'si-placeholder-svg' }}
      </div>
    {% endif %}
  </div>

  {%- comment -%} ── Text panel ── {%- endcomment -%}
  <div class="si-text-panel" style="background: {{ section.settings.text_bg_color }};">
    <div class="si-text-inner">
      {% if section.settings.label != blank %}
        <p class="si-label maison-demi">{{ section.settings.label }}</p>
      {% endif %}

      {% if section.settings.heading != blank %}
        <h2 class="si-heading maison-book">{{ section.settings.heading }}</h2>
      {% endif %}

      {% if section.settings.body != blank %}
        <div class="si-body maison-book">{{ section.settings.body }}</div>
      {% endif %}
    </div>
  </div>
</div>

<style>
  .si-section {
    display: flex;
    flex-direction: column;
    width: 100%;
    background: var(--si-text-bg, #e8e0d8);
  }

  /* ── Image left (default) ── */
  .si-section[data-img-side='right'] {
    flex-direction: column-reverse;
  }

  /* ── Image panel ── */
  .si-image-panel {
    width: 100%;
    /* On mobile: fixed aspect so it doesn't go too tall */
    aspect-ratio: 4 / 3;
    overflow: hidden;
    flex-shrink: 0;
  }

  .si-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    display: block;
  }

  .si-img-placeholder {
    width: 100%;
    height: 100%;
    background: #d1d5db;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .si-placeholder-svg {
    width: 25%;
    height: 25%;
    opacity: 0.15;
  }

  /* ── Text panel ── */
  .si-text-panel {
    display: flex;
    align-items: center;
    justify-content: flex-start;
    padding: 52px 28px;
    width: 100%;
  }

  .si-text-inner {
    width: 100%;
    max-width: 540px;
    display: flex;
    flex-direction: column;
    gap: 18px;
  }

  /* ── Label / eyebrow ── */
  .si-label {
    font-size: 1.3rem;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #000;
    margin: 0;
  }

  /* ── Heading ── */
  .si-heading {
    font-size: clamp(28px, 3.5vw, 40px);
    font-weight: 300;
    line-height: 1.15;
    letter-spacing: -0.01em;
    color: #000;
    margin: 0;
  }

  /* ── Body copy ── */
  .si-body {
    font-size: clamp(13px, 1.1vw, 16px);
    line-height: 1.75;
    letter-spacing: 1.4px;
    color: #000;
  }

  .si-body p {
    margin: 0;
  }
  .si-body p + p {
    margin-top: 12px;
  }

  /* ══════════════════════════════════════
      DESKTOP — side-by-side layout
   ══════════════════════════════════════ */
  @media (min-width: 768px) {
    .si-section {
      flex-direction: row; /* base: image left */
      height: 100vh; /* full viewport height on desktop */
    }

    /* Image-right: reverse the row */
    .si-section[data-img-side='right'] {
      flex-direction: row-reverse;
    }

    /* Image panel: ~52% width, full section height */
    .si-image-panel {
      flex: 0 0 52%;
      aspect-ratio: unset;
      height: 100%; /* fills the 100vh section */
      flex-basis: 50%;
    }

    /* Text panel: remaining ~48% */
    .si-text-panel {
      flex: 1 1 0;
      height: 100%; /* fills the 100vh section */
      /* Generous inset — mimics the generous padding in screenshot */
      padding: clamp(48px, 6vw, 96px) clamp(40px, 5vw, 80px);
      align-items: center;
      justify-content: flex-start;
      flex-basis: 50%;
    }

    .si-text-inner {
      max-width: 480px;
    }
  }

  @media (min-width: 1200px) {
    .si-text-panel {
      padding: 80px clamp(56px, 5vw, 96px);
    }

    .si-text-inner {
      max-width: 520px;
    }
  }
</style>

{% schema %}
{
  "name": "Image + Text Split",
  "tag": "section",
  "class": "image-text-split-section",
  "settings": [
    {
      "type": "header",
      "content": "Image"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "select",
      "id": "image_alignment",
      "label": "Image Side",
      "info": "Which side the image appears on desktop.",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "right", "label": "Right" }
      ],
      "default": "left"
    },
    {
      "type": "header",
      "content": "Text Content"
    },
    {
      "type": "text",
      "id": "label",
      "label": "Eyebrow Label",
      "default": "OUR FACTORIES",
      "info": "Small uppercase label above the heading. Leave blank to hide."
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Our ethical approach."
    },
    {
      "type": "richtext",
      "id": "body",
      "label": "Body Copy",
      "default": "<p>We spend months finding the best factories around the world—the same ones that produce your favorite designer labels. We visit them often and build strong personal relationships with the owners.</p>"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "text_bg_color",
      "label": "Text Panel Background",
      "default": "#e6ded8"
    }
  ],
  "presets": [
    {
      "name": "Image + Text Split",
      "category": "Everlane About Page"
    }
  ]
}
{% endschema %}
