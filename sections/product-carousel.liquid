{%- liquid
  assign collection = collections[section.settings.collection]
  assign products = collection.products
  assign per_page = section.settings.products_per_page | default: 8
-%}

<div class="pc-section" id="pc-{{ section.id }}">
  <div class="pc-header">
    {% if section.settings.heading != blank %}
      <h2 class="pc-heading maison-book">{{ section.settings.heading }}</h2>
    {% endif %}
    {% if section.settings.subtext != blank %}
      <p class="pc-subtext maison-book">{{ section.settings.subtext }}</p>
    {% endif %}
  </div>

  <div class="pc-stage">
    <button class="pc-arrow pc-arrow--prev" aria-label="Previous" data-dir="-1">
      <img src="{{ 'caret-left.svg' | asset_url }}" alt="Caret left icon" height="40" width="40">
    </button>

    <div class="pc-track-wrap">
      <ul class="pc-track" role="list">
        {% for product in products limit: per_page %}
          <li class="pc-slide">
            <a href="{{ product.url }}" class="pc-card">
              <div class="pc-card-img-wrap">
                {% if product.featured_image %}
                  {{
                    product.featured_image
                    | image_url: width: 800
                    | image_tag: class: 'pc-card-img', loading: 'lazy', alt: product.featured_image.alt
                    | default: product.title, widths: '300, 500, 700, 800'
                  }}
                {% else %}
                  <div class="pc-card-img-placeholder">
                    {{ 'product-1' | placeholder_svg_tag: 'pc-placeholder-svg' }}
                  </div>
                {% endif %}
              </div>

              <div class="pc-card-info">
                <div class="pc-card-row">
                  <span class="pc-card-title maison-book">{{ product.title }}</span>
                  <span class="pc-card-price maison-book">{{ product.price | money_without_trailing_zeros }}</span>
                </div>
                {% if product.metafields.custom.variant_label != blank %}
                  <span class="pc-card-variant maison-book">{{ product.metafields.custom.variant_label }}</span>
                {% elsif product.variants.first.title != 'Default Title' %}
                  <span class="pc-card-variant maison-book">{{ product.variants.first.title }}</span>
                {% endif %}
              </div>
            </a>
          </li>
        {% else %}
          {%- for i in (1..5) -%}
            <li class="pc-slide">
              <a href="#" class="pc-card">
                <div class="pc-card-img-wrap">
                  <div class="pc-card-img-placeholder">
                    {{ 'product-' | append: i | placeholder_svg_tag: 'pc-placeholder-svg' }}
                  </div>
                </div>
                <div class="pc-card-info">
                  <div class="pc-card-row">
                    <span class="pc-card-title">Product Title</span>
                    <span class="pc-card-price">$00</span>
                  </div>
                  <span class="pc-card-variant">Variant</span>
                </div>
              </a>
            </li>
          {%- endfor -%}
        {% endfor %}
      </ul>
    </div>

    <button class="pc-arrow pc-arrow--next" aria-label="Next" data-dir="1">
      <img src="{{ 'caret-right.svg' | asset_url }}" alt="Caret right icon" height="40" width="40">
    </button>
  </div>

  <div class="pc-dots" role="tablist" aria-label="Carousel pages"></div>
</div>

<style>
  .pc-section {
    background: #fff;
    padding: 56px 0 64px;
    width: 100%;
    overflow: hidden;
  }

  .pc-header {
    text-align: center;
    padding: 0 24px;
    margin-bottom: 30px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
  }

  .pc-heading {
    font-size: clamp(20px, 2.5vw, 28px);
    color: #000;
    line-height: 1.2;
    margin: 0;
  }

  .pc-subtext {
    font-size: clamp(14px, 1.2vw, 16px);
    color: #000;
    margin: 0;
    line-height: 1.55;
    letter-spacing: 0.64px;
  }

  .pc-stage {
    position: relative;
    display: flex;
    align-items: center;
  }

  .pc-track-wrap {
    overflow: hidden;
    flex: 1;
    margin: 0 48px;
  }

  .pc-track {
    display: flex;
    list-style: none;
    margin: 0;
    padding: 0;
    gap: 8px;
    transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    will-change: transform;
  }

  .pc-slide {
    flex: 0 0 calc((100%) / 1.5);
    min-width: 0;
  }

  .pc-card {
    display: block;
    text-decoration: none;
    color: inherit;
  }

  .pc-card-img-wrap {
    width: 100%;
    aspect-ratio: 2 / 3;
    overflow: hidden;
    background: #f3f4f6;
    margin-bottom: 12px;
  }

  .pc-card-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top center;
    display: block;
    transition: transform 0.5s ease;
  }

  .pc-card:hover .pc-card-img {
    transform: scale(1.04);
  }

  .pc-card-img-placeholder {
    width: 100%;
    height: 100%;
    background: #e5e7eb;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .pc-placeholder-svg {
    width: 50%;
    height: 50%;
    opacity: 0.25;
  }

  .pc-card-info {
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding: 0 2px;
  }

  .pc-card-row {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 12px;
  }

  .pc-card-title {
    font-size: 13px;
    color: #262626;
    line-height: 1.4;
  }

  .pc-card-price {
    font-size: 13px;
    color: #262626;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .pc-card-variant {
    font-size: 12px;
    color: #737373;
    line-height: 1.3;
  }

  .pc-arrow {
    position: absolute;
    top: 38%;
    z-index: 2;
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    color: #111;
    flex-shrink: 0;
  }

  .pc-arrow--prev {
    left: 4px;
  }
  .pc-arrow--next {
    right: 4px;
  }

  .pc-arrow[disabled] {
    opacity: 0.3;
    pointer-events: none;
  }

  .pc-dots {
    display: flex;
    justify-content: center;
    gap: 8px;
    margin-top: 28px;
    padding: 0 24px;
  }

  .pc-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: #d1d5db;
    border: none;
    padding: 0;
    cursor: pointer;
    transition: background 0.2s;
  }

  .pc-dot--active {
    background: #111;
  }

  @media (min-width: 640px) {
    .pc-slide {
      flex: 0 0 calc((100%) / 2.5);
    }

    .pc-track-wrap {
      margin: 0 56px;
    }
  }

  @media (min-width: 1024px) {
    .pc-section {
      padding: 64px 0 72px;
    }

    .pc-slide {
      flex: 0 0 calc((100%) / 4.3);
    }

    .pc-track-wrap {
      margin: 0 64px;
    }

    .pc-arrow--prev {
      left: 8px;
    }
    .pc-arrow--next {
      right: 8px;
    }
  }

  @media (min-width: 1280px) {
    .pc-slide {
      flex: 0 0 calc((100%) / 4.5);
    }
  }
</style>

<script>
  (function () {
    const section = document.getElementById('pc-{{ section.id }}');
    if (!section) return;

    const track = section.querySelector('.pc-track');
    const slides = Array.from(section.querySelectorAll('.pc-slide'));
    const dotsWrap = section.querySelector('.pc-dots');
    const prevBtn = section.querySelector('.pc-arrow--prev');
    const nextBtn = section.querySelector('.pc-arrow--next');

    if (!slides.length) return;

    let current = 0;

    function visibleCount() {
      const w = section.offsetWidth;
      if (w >= 1280) return 4.5;
      if (w >= 1024) return 4.3;
      if (w >= 640) return 2.5;
      return 1.5;
    }

    function pageCount() {
      return Math.ceil(slides.length - Math.floor(visibleCount()) + 1);
    }

    function buildDots() {
      dotsWrap.innerHTML = '';
      const count = pageCount();
      for (let i = 0; i < count; i++) {
        const btn = document.createElement('button');
        btn.className = 'pc-dot' + (i === 0 ? ' pc-dot--active' : '');
        btn.setAttribute('aria-label', 'Go to page ' + (i + 1));
        btn.addEventListener('click', () => goTo(i));
        dotsWrap.appendChild(btn);
      }
    }

    function updateDots() {
      dotsWrap.querySelectorAll('.pc-dot').forEach((d, i) => {
        d.classList.toggle('pc-dot--active', i === current);
      });
    }

    function getSlideWidth() {
      if (!slides[0]) return 0;
      const style = getComputedStyle(track);
      const gap = parseFloat(style.gap) || 8;
      return slides[0].offsetWidth + gap;
    }

    function goTo(index) {
      const max = slides.length - Math.floor(visibleCount());
      current = Math.max(0, Math.min(index, max));
      track.style.transform = 'translateX(-' + current * getSlideWidth() + 'px)';
      updateDots();
      prevBtn.disabled = current === 0;
      nextBtn.disabled = current >= max;
    }

    prevBtn.addEventListener('click', () => goTo(current - 1));
    nextBtn.addEventListener('click', () => goTo(current + 1));

    buildDots();
    goTo(0);

    let resizeTimer;
    window.addEventListener('resize', () => {
      clearTimeout(resizeTimer);
      resizeTimer = setTimeout(() => {
        buildDots();
        goTo(0);
      }, 150);
    });

    let startX = 0;
    track.addEventListener(
      'touchstart',
      (e) => {
        startX = e.touches[0].clientX;
      },
      { passive: true }
    );
    track.addEventListener('touchend', (e) => {
      const diff = startX - e.changedTouches[0].clientX;
      if (Math.abs(diff) > 40) goTo(diff > 0 ? current + 1 : current - 1);
    });
  })();
</script>

{% schema %}
{
  "name": "Product Carousel",
  "tag": "section",
  "class": "product-carousel-section",
  "limit": 1,
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Everlane Favorites"
    },
    {
      "type": "textarea",
      "id": "subtext",
      "label": "Subtext",
      "default": "Beautifully Functional. Purposefully Designed. Consciously Crafted."
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_per_page",
      "label": "Number of Products",
      "min": 4,
      "max": 20,
      "step": 1,
      "default": 10
    }
  ],
  "presets": [
    {
      "name": "Product Carousel",
      "category": "Everlane"
    }
  ]
}
{% endschema %}
