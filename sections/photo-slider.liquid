<div class="ug-section" id="ug-{{ section.id }}">
  <div class="ug-header">
    {% if section.settings.heading != blank %}
      <h2 class="ug-heading">{{ section.settings.heading }}</h2>
    {% endif %}
    <div class="ug-subrow">
      {% if section.settings.subtext != blank %}
        <p class="ug-subtext">{{ section.settings.subtext }}</p>
      {% endif %}
      {% if section.settings.cta_text != blank and section.settings.cta_url != blank %}
        <a href="{{ section.settings.cta_url }}" class="ug-cta">{{ section.settings.cta_text }}</a>
      {% endif %}
    </div>
  </div>

  <div class="ug-stage">
    <button class="ug-arrow ug-arrow--prev" aria-label="Previous">
      <img src="{{ 'caret-left.svg' | asset_url }}" alt="Caret left icon" width="40" height="40">
    </button>

    <div class="ug-track-wrap">
      <ul class="ug-track" role="list">
        {% for block in section.blocks %}
          {% if block.type == 'photo' %}
            <li class="ug-slide" {{ block.shopify_attributes }}>
              <div class="ug-card">
                <div class="ug-img-wrap">
                  {% if block.settings.image != blank %}
                    {{
                      block.settings.image
                      | image_url: width: 800
                      | image_tag: class: 'ug-img', loading: 'lazy', alt: block.settings.alt_text
                      | default: section.settings.heading, widths: '300, 500, 700, 800'
                    }}
                  {% else %}
                    <div class="ug-img-placeholder">
                      {{ 'lifestyle-2' | placeholder_svg_tag: 'ug-placeholder-svg' }}
                    </div>
                  {% endif %}

                  {% if block.settings.product_url != blank %}
                    <a
                      href="{{ block.settings.product_url }}"
                      class="ug-cart-btn"
                      aria-label="Shop this look"
                    >
                      <svg
                        xmlns="http://www.w3.org/2000/svg"
                        width="15"
                        height="15"
                        fill="none"
                        viewBox="0 0 24 24"
                        stroke="currentColor"
                        stroke-width="1.8"
                      >
                        <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/>
                        <line x1="3" y1="6" x2="21" y2="6"/>
                        <path d="M16 10a4 4 0 0 1-8 0"/>
                      </svg>
                    </a>
                  {% endif %}
                </div>
              </div>
            </li>
          {% endif %}
        {% endfor %}
      </ul>
    </div>

    <button class="ug-arrow ug-arrow--next" aria-label="Next">
      <img src="{{ 'caret-right.svg' | asset_url }}" alt="Caret right icon" width="40" height="40">
    </button>
  </div>
</div>

<style>
  .ug-section {
    background: #fff;
    padding: 56px 0 64px;
    width: 100%;
    overflow: hidden;
  }

  .ug-header {
    text-align: center;
    padding: 0 24px;
    margin-bottom: 32px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
  }

  .ug-heading {
    font-size: clamp(22px, 2.5vw, 30px);
    font-weight: 400;
    color: #111;
    letter-spacing: -0.01em;
    line-height: 1.2;
    margin: 0;
  }

  .ug-subrow {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
  }

  .ug-subtext {
    font-size: 14px;
    color: #374151;
    line-height: 1.55;
    margin: 0;
  }

  .ug-cta {
    display: inline-block;
    font-size: 14px;
    color: #111;
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-thickness: 1px;
    transition: opacity 0.15s;
  }

  .ug-cta:hover {
    opacity: 0.55;
  }

  /* ─── Stage: arrows sit outside the track, flush with viewport edges ─── */
  .ug-stage {
    position: relative;
    display: flex;
    align-items: center;
    /* Give horizontal room so arrows don't overlap the first/last card */
    padding: 0 44px;
  }

  .ug-track-wrap {
    overflow: hidden;
    flex: 1;
    min-width: 0;
  }

  .ug-track {
    display: flex;
    list-style: none;
    margin: 0;
    padding: 0;
    gap: 8px;
    transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    will-change: transform;
  }

  /* ─── Slide: portrait cards, height capped to match Image 1 ─── */
  .ug-slide {
    flex: 0 0 calc((100% - 8px * 1) / 1.3); /* ~1 visible + peek on mobile */
    min-width: 0;
  }

  .ug-card {
    position: relative;
    display: flex;
  }

  .ug-img-wrap {
    position: relative;
    /* Enforce portrait 3:4 ratio but cap max-height so cards stay compact
       like the reference screenshot — not full-viewport-height tall */
    aspect-ratio: 3 / 4;
    max-height: 300px;
    overflow: hidden;
    background: #f3f4f6;
    width: 100%;
  }

  .ug-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top center;
    display: block;
    transition: transform 0.5s ease;
  }

  .ug-slide:hover .ug-img {
    transform: scale(1.03);
  }

  .ug-img-placeholder {
    width: 100%;
    height: 100%;
    background: #e5e7eb;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ug-placeholder-svg {
    width: 40%;
    height: 40%;
    opacity: 0.2;
  }

  /* ─── Cart button: circular white pill, top-right of each card ─── */
  .ug-cart-btn {
    position: absolute;
    top: 10px;
    right: 10px;
    width: 34px;
    height: 34px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.92);
    display: flex;
    align-items: center;
    justify-content: center;
    color: #111;
    text-decoration: none;
    backdrop-filter: blur(4px);
    box-shadow: 0 1px 4px rgba(0, 0, 0, 0.12);
    transition: background 0.2s, transform 0.2s;
  }

  .ug-cart-btn:hover {
    background: #fff;
    transform: scale(1.08);
  }

  /* ─── Arrows: positioned absolute outside the track-wrap ─── */
  .ug-arrow {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 10;
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: transparent;
    border: none;
    cursor: pointer;
    color: #6b7280;
    padding: 0;
    transition: color 0.2s;
    flex-shrink: 0;
  }

  .ug-arrow:hover {
    color: #111;
  }

  /* Arrows sit just inside the stage padding, outside the track-wrap */
  .ug-arrow--prev {
    left: 8px;
  }
  .ug-arrow--next {
    right: 8px;
  }

  .ug-arrow[disabled] {
    opacity: 0.2;
    pointer-events: none;
  }

  /* ── 640px – 2 cards visible ── */
  @media (min-width: 640px) {
    .ug-stage {
      padding: 0 44px;
    }

    .ug-slide {
      flex: 0 0 calc((100% - 8px) / 2.2);
    }

    .ug-img-wrap {
      max-height: 260px;
    }
  }

  /* ── 1024px – ~4.5 cards visible, matching the reference screenshot ── */
  @media (min-width: 1024px) {
    .ug-section {
      padding: 64px 0 72px;
    }

    .ug-stage {
      /* Wider padding so arrows have comfortable breathing room */
      padding: 0 52px;
    }

    .ug-slide {
      flex: 0 0 calc((100% - 8px * 3) / 4.5);
    }

    .ug-img-wrap {
      /* This is the key fix: Image 1 cards are clearly shorter than full portrait.
         A fixed max-height keeps them compact and consistent with the reference. */
      max-height: 225px;
      aspect-ratio: auto; /* Let max-height drive the height on desktop */
      height: 225px;
    }

    .ug-arrow--prev {
      left: 12px;
    }
    .ug-arrow--next {
      right: 12px;
    }
  }

  /* ── 1280px – ~4.8 cards visible ── */
  @media (min-width: 1280px) {
    .ug-stage {
      padding: 0 56px;
    }

    .ug-slide {
      flex: 0 0 calc((100% - 8px * 3) / 4.8);
    }

    .ug-img-wrap {
      max-height: 240px;
      height: 240px;
    }
  }
</style>

<script>
  (function () {
    const section = document.getElementById('ug-{{ section.id }}');
    if (!section) return;

    const track = section.querySelector('.ug-track');
    const slides = Array.from(section.querySelectorAll('.ug-slide'));
    const prevBtn = section.querySelector('.ug-arrow--prev');
    const nextBtn = section.querySelector('.ug-arrow--next');
    const total = slides.length;

    if (total === 0) return;

    let current = 0;

    function visibleCount() {
      const w = section.offsetWidth;
      if (w >= 1280) return 4.8;
      if (w >= 1024) return 4.5;
      if (w >= 640) return 2.2;
      return 1.3;
    }

    function getSlideWidth() {
      const gap = parseFloat(getComputedStyle(track).gap) || 8;
      return slides[0].offsetWidth + gap;
    }

    function maxIndex() {
      return Math.max(0, total - Math.floor(visibleCount()));
    }

    function goTo(index) {
      current = Math.max(0, Math.min(index, maxIndex()));
      track.style.transform = 'translateX(-' + current * getSlideWidth() + 'px)';
      prevBtn.disabled = current === 0;
      nextBtn.disabled = current >= maxIndex();
    }

    prevBtn.addEventListener('click', () => goTo(current - 1));
    nextBtn.addEventListener('click', () => goTo(current + 1));

    let startX = 0;
    track.addEventListener(
      'touchstart',
      (e) => {
        startX = e.touches[0].clientX;
      },
      { passive: true }
    );
    track.addEventListener('touchend', (e) => {
      const diff = startX - e.changedTouches[0].clientX;
      if (Math.abs(diff) > 40) goTo(diff > 0 ? current + 1 : current - 1);
    });

    let resizeTimer;
    window.addEventListener('resize', () => {
      clearTimeout(resizeTimer);
      resizeTimer = setTimeout(() => goTo(0), 150);
    });

    goTo(0);
  })();
</script>

{% schema %}
{
  "name": "UGC Photo Slider",
  "tag": "section",
  "class": "ugc-slider-section",
  "limit": 1,
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Everlane On You"
    },
    {
      "type": "textarea",
      "id": "subtext",
      "label": "Subtext",
      "default": "Share your latest look with #EverlaneOnYou for a chance to be featured."
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "CTA Link Text",
      "default": "Add Your Photo"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "CTA Link URL"
    }
  ],
  "blocks": [
    {
      "type": "photo",
      "name": "Photo",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Photo"
        },
        {
          "type": "text",
          "id": "alt_text",
          "label": "Alt Text",
          "default": "Customer photo"
        },
        {
          "type": "url",
          "id": "product_url",
          "label": "Shop Link URL",
          "info": "Adds a cart icon on the photo. Leave blank to hide."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "UGC Photo Slider",
      "category": "Everlane",
      "blocks": [
        { "type": "photo" },
        { "type": "photo" },
        { "type": "photo" },
        { "type": "photo" },
        { "type": "photo" }
      ]
    }
  ]
}
{% endschema %}
