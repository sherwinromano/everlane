<div class="ec-section" id="ec-{{ section.id }}">
  <div class="ec-track-wrap">
    <div class="ec-track">
      {% for block in section.blocks %}
        {% if block.type == 'card' %}
          <div class="ec-slide" {{ block.shopify_attributes }}>
            {% if block.settings.heading != blank %}
              <h3 class="ec-heading maison-book">{{ block.settings.heading }}</h3>
            {% endif %}

            <div class="ec-img-wrap">
              {% if block.settings.image != blank %}
                {{
                  block.settings.image
                  | image_url: width: 1200
                  | image_tag:
                    class: 'ec-img',
                    loading: 'lazy',
                    alt: block.settings.heading,
                    widths: '400, 600, 800, 1000, 1200'
                }}
              {% else %}
                <div class="ec-img-placeholder">
                  {{ 'lifestyle-1' | placeholder_svg_tag: 'ec-placeholder-svg' }}
                </div>
              {% endif %}
            </div>

            <div class="ec-body">
              {% if block.settings.subtext != blank %}
                <p class="ec-subtext maison-book">{{ block.settings.subtext }}</p>
              {% endif %}
              {% if block.settings.cta_text != blank and block.settings.cta_url != blank %}
                <a href="{{ block.settings.cta_url }}" class="ec-cta maison-book">
                  {{ block.settings.cta_text }}
                </a>
              {% endif %}
            </div>
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>

  <div class="ec-mobile-nav">
    <button class="ec-mob-prev" aria-label="Previous">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="16"
        height="16"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
        stroke-width="1.5"
      >
        <polyline points="15 18 9 12 15 6"/>
      </svg>
    </button>
    <div class="ec-dots">
      {% for block in section.blocks %}
        {% if block.type == 'card' %}
          <button
            class="ec-dot {% if forloop.first %}ec-dot--active{% endif %}"
            aria-label="Go to slide {{ forloop.index }}"
          ></button>
        {% endif %}
      {% endfor %}
    </div>
    <button class="ec-mob-next" aria-label="Next">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="16"
        height="16"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
        stroke-width="1.5"
      >
        <polyline points="9 18 15 12 9 6"/>
      </svg>
    </button>
  </div>
</div>

<style>
  .ec-section {
    background: #fff;
    padding: 48px 24px 56px;
    width: 100%;
    overflow: hidden;
  }

  .ec-track-wrap {
    overflow: hidden;
    width: 100%;
  }

  .ec-track {
    display: flex;
    gap: 24px;
    transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    will-change: transform;
  }

  .ec-slide {
    flex: 0 0 100%;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .ec-heading {
    font-size: clamp(16px, 2vw, 20px);
    font-weight: 400;
    color: #111;
    letter-spacing: 0;
    line-height: 1.3;
    margin: 0 0 16px 0;
    text-align: center;
  }

  .ec-img-wrap {
    width: 100%;
    aspect-ratio: 4 / 3.6;
    overflow: hidden;
    background: #f3f4f6;
  }

  .ec-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
    transition: transform 0.5s ease;
  }

  .ec-slide:hover .ec-img {
    transform: scale(1.03);
  }

  .ec-img-placeholder {
    width: 100%;
    height: 100%;
    background: #e5e7eb;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ec-placeholder-svg {
    width: 40%;
    height: 40%;
    opacity: 0.2;
  }

  .ec-body {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
    padding: 20px 8px 0;
    text-align: center;
  }

  .ec-subtext {
    font-size: 14px;
    color: #262626;
    line-height: 1.6;
    letter-spacing: 0.03em;
    margin: 0;
  }

  .ec-cta {
    display: inline-block;
    font-size: 13px;
    color: #262626;
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-thickness: 1px;
    transition: opacity 0.15s;
  }

  .ec-cta:hover {
    opacity: 0.55;
  }

  .ec-mobile-nav {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 16px;
    padding-top: 28px;
  }

  .ec-mob-prev,
  .ec-mob-next {
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: transparent;
    border: 1px solid #d1d5db;
    cursor: pointer;
    color: #374151;
    transition: color 0.2s, border-color 0.2s;
    padding: 0;
    flex-shrink: 0;
  }

  .ec-mob-prev:hover,
  .ec-mob-next:hover {
    color: #111;
    border-color: #111;
  }

  .ec-mob-prev[disabled],
  .ec-mob-next[disabled] {
    opacity: 0.25;
    pointer-events: none;
  }

  .ec-dots {
    display: flex;
    gap: 8px;
    align-items: center;
  }

  .ec-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: #d1d5db;
    border: none;
    padding: 0;
    cursor: pointer;
    transition: background 0.2s;
  }

  .ec-dot--active {
    background: #111;
  }

  @media (min-width: 640px) {
    .ec-section {
      padding: 56px 40px 64px;
    }

    .ec-track {
      gap: 24px;
      transform: none !important;
    }

    .ec-slide {
      flex: 0 0 calc(50% - 12px);
    }

    .ec-mobile-nav {
      display: none;
    }
  }

  @media (min-width: 1024px) {
    .ec-section {
      padding: 64px 64px 72px;
    }

    .ec-heading {
      font-size: 22px;
    }
  }

  @media (min-width: 1280px) {
    .ec-section {
      padding: 72px 80px 80px;
    }
  }
</style>

<script>
  (function () {
    const section = document.getElementById('ec-{{ section.id }}');
    if (!section) return;

    const track = section.querySelector('.ec-track');
    const slides = Array.from(section.querySelectorAll('.ec-slide'));
    const mobPrev = section.querySelector('.ec-mob-prev');
    const mobNext = section.querySelector('.ec-mob-next');
    const dots = Array.from(section.querySelectorAll('.ec-dot'));
    const total = slides.length;

    let current = 0;
    let isMobile = window.innerWidth < 640;

    function updateDots() {
      dots.forEach((d, i) => d.classList.toggle('ec-dot--active', i === current));
    }

    function getSlideWidth() {
      if (!slides[0]) return 0;
      const gap = 24;
      return slides[0].offsetWidth + gap;
    }

    function goTo(index) {
      if (!isMobile) return;
      current = Math.max(0, Math.min(index, total - 1));
      track.style.transform = 'translateX(-' + current * getSlideWidth() + 'px)';
      if (mobPrev) mobPrev.disabled = current === 0;
      if (mobNext) mobNext.disabled = current === total - 1;
      updateDots();
    }

    function onResize() {
      const wasMobile = isMobile;
      isMobile = window.innerWidth < 640;
      if (!isMobile) {
        track.style.transform = '';
        current = 0;
      } else if (!wasMobile) {
        goTo(0);
      }
    }

    if (mobPrev) mobPrev.addEventListener('click', () => goTo(current - 1));
    if (mobNext) mobNext.addEventListener('click', () => goTo(current + 1));
    dots.forEach((d, i) => d.addEventListener('click', () => goTo(i)));

    let startX = 0;
    track.addEventListener(
      'touchstart',
      (e) => {
        startX = e.touches[0].clientX;
      },
      { passive: true }
    );
    track.addEventListener('touchend', (e) => {
      const diff = startX - e.changedTouches[0].clientX;
      if (Math.abs(diff) > 40) goTo(diff > 0 ? current + 1 : current - 1);
    });

    let resizeTimer;
    window.addEventListener('resize', () => {
      clearTimeout(resizeTimer);
      resizeTimer = setTimeout(onResize, 150);
    });

    goTo(0);
  })();
</script>

{% schema %}
{
  "name": "Editorial Cards",
  "tag": "section",
  "class": "editorial-cards-section",
  "limit": 1,
  "max_blocks": 2,
  "settings": [],
  "blocks": [
    {
      "type": "card",
      "name": "Card",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Our Holiday Gift Picks"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "textarea",
          "id": "subtext",
          "label": "Subtext",
          "default": "The best presents for everyone on your list."
        },
        {
          "type": "text",
          "id": "cta_text",
          "label": "Link Text",
          "default": "Read More"
        },
        {
          "type": "url",
          "id": "cta_url",
          "label": "Link URL"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Editorial Cards",
      "category": "Everlane",
      "blocks": [
        {
          "type": "card",
          "settings": {
            "heading": "Our Holiday Gift Picks",
            "subtext": "The best presents for everyone on your list.",
            "cta_text": "Read More"
          }
        },
        {
          "type": "card",
          "settings": {
            "heading": "Cleaner Fashion",
            "subtext": "See the sustainability efforts behind each of our products.",
            "cta_text": "Learn More"
          }
        }
      ]
    }
  ]
}
{% endschema %}
