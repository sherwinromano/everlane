<div class="op-section" id="op-{{ section.id }}">
  {% if section.settings.heading != blank %}
    <h2 class="op-heading maison-demi">{{ section.settings.heading }}</h2>
  {% endif %}

  <ul class="op-grid" role="list">
    {% for block in section.blocks %}
      {% if block.type == 'card' %}
        <li class="op-item" {{ block.shopify_attributes }}>
          {% if block.settings.url != blank %}
            <a href="{{ block.settings.url }}" class="op-card">
          {% else %}
            <div class="op-card">
          {% endif %}

          <div class="op-img-wrap">
            {% if block.settings.image != blank %}
              {{
                block.settings.image
                | image_url: width: 1000
                | image_tag:
                  class: 'op-img',
                  loading: 'lazy',
                  alt: block.settings.label,
                  widths: '400, 600, 800, 1000',
                  sizes: '(min-width: 1024px) 33vw, (min-width: 768px) 33vw, 100vw'
              }}
            {% else %}
              <div class="op-img-placeholder">
                {{ 'lifestyle-2' | placeholder_svg_tag: 'op-placeholder-svg' }}
              </div>
            {% endif %}
          </div>

          {% if block.settings.label != blank %}
            <p class="op-label maison-book">{{ block.settings.label }}</p>
          {% endif %}

          {% if block.settings.url != blank %}
            </a>
          {% else %}
            </div>
          {% endif %}
        </li>
      {% endif %}
    {% endfor %}
  </ul>
</div>

<style>
  /* ── Section ── */
  .op-section {
    width: 100%;
    background: #fff;
    padding: 40px 20px 52px;
  }

  /* ── Heading — bold, left-aligned ── */
  .op-heading {
    font-size: clamp(26px, 5vw, 34px);
    color: #000;
    letter-spacing: 0;
    line-height: 1.1;
    margin-bottom: 12px;
  }

  /* ── Grid — mobile: 1 column ── */
  .op-grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: 32px;
  }

  /* ── Card ── */
  .op-card {
    display: flex;
    flex-direction: column;
    gap: 16px;
    text-decoration: none;
    color: inherit;
  }

  .op-img-wrap {
    width: 100%;
    overflow: hidden;
    background: #f3f4f6;
  }

  .op-img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    transition: transform 0.5s ease;
  }

  .op-card:hover .op-img {
    transform: scale(1.03);
  }

  .op-img-placeholder {
    width: 100%;
    height: 100%;
    background: #e5e7eb;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .op-placeholder-svg {
    width: 30%;
    height: 30%;
    opacity: 0.15;
  }

  /* ── Caption label — larger, left-aligned ── */
  .op-label {
    font-size: clamp(18px, 2vw, 24px);
    color: #000;
    line-height: 1.3;
    margin: 0;
    letter-spacing: 0;
  }

  /* ── Tablet: 768px — 3 columns ── */
  @media (min-width: 768px) {
    .op-section {
      padding: 52px 32px 64px;
    }

    .op-grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 24px;
    }
  }

  /* ── Large desktop: 1024px ── */
  @media (min-width: 1024px) {
    .op-section {
      padding: 120px 60px;
    }

    .op-grid {
      gap: 28px;
    }
  }
</style>

{% schema %}
{
  "name": "Our Progress",
  "tag": "section",
  "class": "our-progress-section",
  "limit": 1,
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Our Progress"
    }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Card",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Caption",
          "default": "Carbon Commitment"
        },
        {
          "type": "url",
          "id": "url",
          "label": "Link URL",
          "info": "Makes the entire card clickable. Leave blank for no link."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Our Progress",
      "category": "Everlane Stories",
      "blocks": [
        { "type": "card", "settings": { "label": "Carbon Commitment" } },
        { "type": "card", "settings": { "label": "Environmental Initiatives" } },
        { "type": "card", "settings": { "label": "Better Factories" } }
      ]
    }
  ]
}
{% endschema %}
