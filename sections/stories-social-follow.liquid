<div
  class="sf-section"
  id="sf-{{ section.id }}"
  style="--sf-bg: {{ section.settings.bg_color }}; --sf-heading-color: {{ section.settings.heading_color }}; --sf-btn-bg: {{ section.settings.btn_bg_color }}; --sf-btn-color: {{ section.settings.btn_text_color }}; --sf-btn-border: {{ section.settings.btn_border_color }};"
>
  <div class="sf-inner">
    {% if section.settings.heading != blank %}
      <h2 class="sf-heading maison-demi">{{ section.settings.heading }}</h2>
    {% endif %}

    {% if section.settings.btn_text != blank and section.settings.btn_url != blank %}
      <a href="{{ section.settings.btn_url }}" class="sf-btn maison-demi">
        {{ section.settings.btn_text }}
      </a>
    {% endif %}
  </div>
</div>

<style>
  /* ── Section ── */
  .sf-section {
    width: 100%;
    background: var(--sf-bg, #000);
    padding: 52px 24px;
  }

  /* ── Inner content — left-aligned ── */
  .sf-inner {
    width: 100%;
    max-width: 1400px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 28px;
  }

  /* ── Heading ── */
  .sf-heading {
    font-size: clamp(28px, 5vw, 52px);
    color: var(--sf-heading-color, #fff);
    letter-spacing: -0.02em;
    line-height: 1.1;
    margin: 0;
  }

  /* ── Button — white pill, dark text ── */
  .sf-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 14px 28px;
    font-size: 14px;
    letter-spacing: 0.01em;
    color: var(--sf-btn-color, #111);
    background: var(--sf-btn-bg, #fff);
    border: 1px solid var(--sf-btn-border, #fff);
    border-radius: 6px;
    text-decoration: none;
    white-space: nowrap;
    transition: background 0.2s, color 0.2s, border-color 0.2s;
  }

  .sf-btn:hover {
    background: transparent;
    color: var(--sf-btn-bg, #fff);
    border-color: var(--sf-btn-bg, #fff);
  }

  /* ── Tablet: 768px ── */
  @media (min-width: 768px) {
    .sf-section {
      padding: 64px 40px;
    }

    .sf-inner {
      gap: 32px;
    }
  }

  /* ── Large desktop: 1024px ── */
  @media (min-width: 1024px) {
    .sf-section {
      padding: 80px 64px;
    }

    .sf-inner {
      gap: 36px;
    }

    .sf-btn {
      padding: 16px 32px;
      font-size: 15px;
    }
  }
</style>

{% schema %}
{
  "name": "Social Follow Banner",
  "tag": "section",
  "class": "social-follow-section",
  "limit": 1,
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Follow us on social for more"
    },
    {
      "type": "text",
      "id": "btn_text",
      "label": "Button Text",
      "default": "@Everlane Instagram"
    },
    {
      "type": "url",
      "id": "btn_url",
      "label": "Button URL"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "btn_bg_color",
      "label": "Button Background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "btn_text_color",
      "label": "Button Text Color",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "btn_border_color",
      "label": "Button Border Color",
      "default": "#ffffff"
    }
  ],
  "presets": [
    {
      "name": "Social Follow Banner",
      "category": "Everlane Stories"
    }
  ]
}
{% endschema %}
