<div class="tp" id="tp-{{ section.id }}">
  <div class="tp__header">
    {%- if section.settings.heading != blank -%}
      <h2 class="tp__heading maison-demi">{{ section.settings.heading }}</h2>
    {%- endif -%}

    {%- if section.settings.description != blank -%}
      <p class="tp__description maison-book">{{ section.settings.description }}</p>
    {%- endif -%}
  </div>

  {%- if section.blocks.size > 0 -%}
    <ul class="tp__grid" role="list">
      {%- for block in section.blocks -%}
        {%- if block.type == 'cost_item' -%}
          <li class="tp__item" {{ block.shopify_attributes }}>
            <div class="tp__icon-wrap">
              {%- if block.settings.icon != blank -%}
                {{
                  block.settings.icon
                  | image_url: width: 160
                  | image_tag:
                    class: 'tp__icon',
                    alt: block.settings.label,
                    width: 80,
                    height: 80,
                    loading: 'lazy',
                    widths: '80, 120, 160',
                    sizes: '(min-width: 1024px) 80px, (min-width: 768px) 72px, 64px'
                }}
              {%- else -%}
                <div class="tp__icon-placeholder">
                  {{- 'image' | placeholder_svg_tag: 'tp__icon-placeholder-svg' -}}
                </div>
              {%- endif -%}
            </div>

            <div class="tp__meta">
              {%- if block.settings.label != blank -%}
                <span class="tp__label maison-book">{{ block.settings.label }}</span>
              {%- endif -%}
              {%- if block.settings.price != blank -%}
                <span class="tp__price maison-book">{{ block.settings.price }}</span>
              {%- endif -%}
            </div>
          </li>
        {%- endif -%}
      {%- endfor -%}
    </ul>
  {%- endif -%}
</div>

<style>
  /* =============================================
     BLOCK: tp (Transparent Pricing)
     Architecture: BEM
     Breakpoints: 768px (tablet), 1024px (desktop)
  ============================================= */

  /* ── Block ── */
  .tp {
    background: {{ section.settings.bg_color }};
    padding: 52px 24px 60px;
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  /* ── Element: header ── */
  .tp__header {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
    margin-bottom: 48px;

  }

  /* ── Element: heading ── */
  .tp__heading {
    font-size: clamp(20px, 3vw, 26px);
    font-weight: 700;
    color: {{ section.settings.heading_color }};
    letter-spacing: -0.01em;
    line-height: 1.2;
    text-align: center;
    margin: 0;
  }

  /* ── Element: description ── */
  .tp__description {
    font-size: clamp(14px, 1.2vw, 16px);
    color: #262626;
    line-height: 1.7;
    text-align: center;
    margin: 0;
    letter-spacing: 0;
  }

  /* ── Element: grid — mobile: 2 columns ── */
  .tp__grid {
    list-style: none;
    align-self: stretch;
    padding: 0;
    margin-inline: auto;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 36px 45px;
    max-width: 80%;
  }

  /* ── Element: item ── */
  .tp__item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 24px;
  }

  /* ── Element: icon-wrap ── */
  .tp__icon-wrap {
    width: 80px;
    height: 80px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  /* ── Element: icon ── */
  .tp__icon {
    width: 80px;
    height: 80px;
    object-fit: contain;
    display: block;
  }

  /* ── Element: icon-placeholder ── */
  .tp__icon-placeholder {
    width: 80px;
    height: 80px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #f3f4f6;
    border-radius: 4px;
  }

  .tp__icon-placeholder-svg {
    width: 50%;
    height: 50%;
    opacity: 0.2;
  }

  /* ── Element: meta ── */
  .tp__meta {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 3px;
  }

  /* ── Element: label ── */
  .tp__label {
    font-size: 15px;
    font-weight: 400;
    color: #262626;
    text-align: center;
    line-height: 1.4;
    letter-spacing: 0.01em;
  }

  /* ── Element: price ── */
  .tp__price {
    font-size: 15px;
    font-weight: 400;
    color: #262626;
    text-align: center;
    line-height: 1.4;
    letter-spacing: 0.01em;
  }

  @media (min-width: 640px) {
    .tp__grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 40px 40px;
    }
  }

  /* ── Tablet: 768px — 3–4 columns ── */
  @media (min-width: 768px) {
    .tp {
      padding: 60px 40px 68px;
    }

    .tp__header {
      max-width: 80%;
    }

    .tp__grid {
      /* Auto-fit: spreads all blocks evenly in one row */
      grid-template-columns: repeat(auto-fit, minmax(100px, 1fr));
      gap: 0 24px;
      max-width: 860px;
    }

  }

  /* ── Large desktop: 1024px — all items in one row ── */
  @media (min-width: 1024px) {
    .tp {
      padding: 72px 48px 80px;
    }

    .tp__header {
      margin-bottom: 56px;
      max-width: 60%;
    }


  }
</style>

{% schema %}
{
  "name": "Transparent Pricing",
  "tag": "section",
  "class": "transparent-pricing-section",
  "limit": 1,
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Transparent Pricing"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "We publish what it costs us to make every one of our products. There are a lot of costs we can't neatly account for - like design, fittings, wear testing, rent on office and retail space - but we believe you deserve to know what goes into making the products you love."
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background",
      "default": "#ffffff"
    }
  ],
  "blocks": [
    {
      "type": "cost_item",
      "name": "Cost Item",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon / Image",
          "info": "Recommended: SVG or PNG with transparent background, at least 160×160px."
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Materials"
        },
        {
          "type": "text",
          "id": "price",
          "label": "Price",
          "default": "$47.96",
          "info": "Enter as plain text e.g. $47.96"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Transparent Pricing",
      "category": "Everlane",
      "blocks": [
        { "type": "cost_item", "settings": { "label": "Materials", "price": "$47.96" } },
        { "type": "cost_item", "settings": { "label": "Hardware", "price": "$5.74" } },
        { "type": "cost_item", "settings": { "label": "Labor", "price": "$13.75" } },
        { "type": "cost_item", "settings": { "label": "Duties", "price": "$8.09" } },
        { "type": "cost_item", "settings": { "label": "Transport", "price": "$1.53" } }
      ]
    }
  ]
}
{% endschema %}
