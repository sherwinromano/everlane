<div class="eh-section" id="eh-{{ section.id }}">
  <div class="eh-inner">
    {% if section.settings.heading != blank %}
      <h1 class="eh-heading maison-demi">{{ section.settings.heading }}</h1>
    {% endif %}

    {% if section.settings.subtext != blank %}
      <p class="eh-subtext maison-book">{{ section.settings.subtext }}</p>
    {% endif %}
  </div>
</div>

<style>
  /* ── Section ── */
  .eh-section {
    width: 100%;
    display: flex;
    padding: 40px 16px;
  }

  /* ── Inner constrained wrapper ── */
  .eh-inner {
    width: 100%;
    max-width: 1400px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    border-top: 14px solid {{ section.settings.border_color }};
    gap: 12px;
  }

  /* ── Heading — massive, bold, left-aligned ── */
  .eh-heading {
    font-size: clamp(56px, 14vw, 160px);

    line-height: 0.95;
    letter-spacing: -0.03em;
    color: #000;
    margin: 0;
    word-break: break-word;
    padding-top: 14px;
  }

  /* ── Subtext ── */
  .eh-subtext {
    font-size: clamp(13px, 1.3vw, 24px);

    line-height: 1.65;
    color: #000;
    margin: 0;
    white-space: pre-line; /* preserves line breaks entered in textarea */
  }

  .eh-heading, .eh-subtext {
    text-align: center;
  }

  /* ── Tablet: 768px ── */
  @media (min-width: 768px) {
    .eh-section {
        padding: 60px 64px;
    }

    .eh-inner {
      gap: 16px;
    }

    .eh-heading, .eh-subtext {
      text-align: start;
    }
  }

  /* ── Large desktop: 1024px ── */
  @media (min-width: 1024px) {


    .eh-inner {
      gap: 20px;
    }
  }
</style>

{% schema %}
{
  "name": "Editorial Header",
  "tag": "section",
  "class": "editorial-header-section",
  "limit": 1,
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "everworld"
    },
    {
      "type": "textarea",
      "id": "subtext",
      "label": "Subtext",
      "info": "Use line breaks to split into multiple lines.",
      "default": "We're on a mission to clean up a dirty industry.\nThese are the people, stories, and ideas that will help us get there."
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Border color",
      "default": "#262626"
    }
  ],
  "presets": [
    {
      "name": "Editorial Header",
      "category": "Everlane Stories"
    }
  ]
}
{% endschema %}
