<div class="me-section" id="me-{{ section.id }}">
  {% if section.settings.heading != blank %}
    <h2 class="me-heading maison-book">{{ section.settings.heading }}</h2>
  {% endif %}

  <ul class="me-grid" role="list">
    {% for block in section.blocks %}
      {% if block.type == 'card' %}
        <li class="me-item" {{ block.shopify_attributes }}>
          {% if block.settings.url != blank %}
            <a href="{{ block.settings.url }}" class="me-card">
          {% else %}
            <div class="me-card">
          {% endif %}

          <div class="me-img-wrap">
            {% if block.settings.image != blank %}
              {{
                block.settings.image
                | image_url: width: 1200
                | image_tag:
                  class: 'me-img',
                  loading: 'lazy',
                  alt: block.settings.label,
                  widths: '400, 600, 800, 1000, 1200',
                  sizes: '(min-width: 1024px) 33vw, (min-width: 768px) 33vw, 100vw'
              }}
            {% else %}
              <div class="me-img-placeholder">
                {{ 'lifestyle-2' | placeholder_svg_tag: 'me-placeholder-svg' }}
              </div>
            {% endif %}
          </div>

          {% if block.settings.label != blank %}
            <p class="me-label maison-demi">{{ block.settings.label }}</p>
          {% endif %}

          {% if block.settings.url != blank %}
            </a>
          {% else %}
            </div>
          {% endif %}
        </li>
      {% endif %}
    {% endfor %}
  </ul>
</div>

<style>
  /* ── Section wrapper ── */
  .me-section {
    width: 100%;
    background: #fff;
    padding: 40px 20px 48px;
  }

  /* ── Heading ── */
  .me-heading {
    font-size: clamp(22px, 5vw, 32px);
    color: #000;
    text-align: center;
    margin: 0 0 20px;
  }

  /* ── Grid — mobile: single column ── */
  .me-grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: 24px;
  }

  /* ── Card ── */
  .me-card {
    display: block;
    text-decoration: none;
    color: inherit;
  }

  /* ── Image wrapper — landscape 16:10 ratio ── */
  .me-img-wrap {
    width: 100%;
    aspect-ratio: 16 / 10;
    overflow: hidden;
    background: #f3f4f6;
  }

  .me-img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    transition: transform 0.5s ease;
  }

  .me-card:hover .me-img {
    transform: scale(1.03);
  }

  .me-img-placeholder {
    width: 100%;
    height: 100%;
    background: #e5e7eb;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .me-placeholder-svg {
    width: 30%;
    height: 30%;
    opacity: 0.15;
  }

  /* ── Caption label ── */
  .me-label {
    font-size: 14px;
    color: #4c4c4b;
    text-align: center;
    margin: 12px 0 0;
    letter-spacing: 0.01em;
    line-height: 1.4;
  }

  /* ── Tablet: 768px — 3 columns ── */
  @media (min-width: 768px) {
    .me-section {
      padding: 80px 40px;
    }

    .me-grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 20px;
    }
  }

  /* ── Large desktop: 1024px ── */
  @media (min-width: 1024px) {
    .me-section {
      padding: 80px 200px;
    }

    .me-grid {
      gap: 24px;
    }

    .me-label {
      font-size: 16px;
      margin-top: 14px;
    }
  }
</style>

{% schema %}
{
  "name": "More to Explore",
  "tag": "section",
  "class": "more-to-explore-section",
  "limit": 1,
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "More to Explore"
    }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Card",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Caption",
          "default": "Our Products"
        },
        {
          "type": "url",
          "id": "url",
          "label": "Link URL",
          "info": "Makes the entire card clickable. Leave blank for no link."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "More to Explore",
      "category": "Everlane About Page",
      "blocks": [
        {
          "type": "card",
          "settings": { "label": "Our Products" }
        },
        {
          "type": "card",
          "settings": { "label": "Our Stores" }
        },
        {
          "type": "card",
          "settings": { "label": "Careers" }
        }
      ]
    }
  ]
}
{% endschema %}
