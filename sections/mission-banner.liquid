<div class="ib-section">
  <div class="ib-wrap">
    <div class="ib-media">
      {% if section.settings.image != blank %}
        {{
          section.settings.image
          | image_url: width: 2000
          | image_tag:
            class: 'ib-img',
            loading: 'lazy',
            alt: section.settings.heading,
            widths: '600, 900, 1200, 1600, 2000'
        }}
      {% else %}
        <div class="ib-placeholder">
          {{ 'lifestyle-1' | placeholder_svg_tag: 'ib-placeholder-svg' }}
        </div>
      {% endif %}
      <div class="ib-scrim"></div>
    </div>

    <div class="ib-content">
      {% if section.settings.heading != blank %}
        <h2 class="ib-heading maison-book">{{ section.settings.heading }}</h2>
      {% endif %}
      {% if section.settings.subtext != blank %}
        <p class="ib-subtext">{{ section.settings.subtext }}</p>
      {% endif %}
      {% if section.settings.cta_text != blank and section.settings.cta_url != blank %}
        <a href="{{ section.settings.cta_url }}" class="ib-cta maison-book">
          {{ section.settings.cta_text }}
        </a>
      {% endif %}
    </div>
  </div>
</div>

<style>
  .ib-section {
    width: 100%;
    background: #fff;
    padding: 90px 24px;
  }

  .ib-wrap {
    position: relative;
    overflow: hidden;
    max-width: 1360px;
    margin: 0 auto;
    height: 340px;
  }

  .ib-media {
    position: absolute;
    inset: 0;
  }

  .ib-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center center;
    display: block;
  }

  .ib-placeholder {
    width: 100%;
    height: 100%;
    background: #4b5563;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ib-placeholder-svg {
    width: 40%;
    height: 40%;
    opacity: 0.2;
  }

  .ib-scrim {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.22);
  }

  .ib-content {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 24px 20px;
    gap: 14px;
  }

  .ib-heading {
    color: #fff;
    font-size: clamp(20px, 3.5vw, 32px);
    line-height: 1.2;
    margin: 0;
    max-width: 700px;
  }

  .ib-subtext {
    color: #fff;
    font-size: clamp(14px, 1.2vw, 16px);
    margin: 0;
    max-width: 520px;
  }

  .ib-cta {
    display: inline-block;
    margin-top: 20px;
    background: #fff;
    color: #262626;
    font-size: 14px;
    letter-spacing: 1.4px;
    text-transform: uppercase;
    text-decoration: none;
    padding: 12px 50px;
    white-space: nowrap;
    transition: background 0.2s ease, color 0.2s ease;
  }

  .ib-cta:hover {
    background: #111;
    color: #fff;
  }

  @media (min-width: 640px) {
    .ib-wrap {
      height: 400px;
    }

    .ib-content {
      gap: 16px;
    }
  }

  @media (min-width: 1024px) {
    .ib-section {
      padding-inline: 40px;
    }

    .ib-wrap {
      height: 460px;
    }

    .ib-content {
      gap: 18px;
      padding: 40px;
    }
  }

  @media (min-width: 1280px) {
    .ib-wrap {
      height: 480px;
    }
  }
</style>

{% schema %}
{
  "name": "Mission Banner",
  "tag": "section",
  "class": "image-banner-section",
  "limit": 1,
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background Image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "We're on a Mission To Clean Up the Industry"
    },
    {
      "type": "textarea",
      "id": "subtext",
      "label": "Subtext",
      "default": "Read about our progress in our latest Impact Report."
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "Button Text",
      "default": "Learn More"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "Button URL"
    }
  ],
  "presets": [
    {
      "name": "Mission Banner",
      "category": "Everlane"
    }
  ]
}
{% endschema %}
