<section class="sbc-section">
  <div class="sbc-heading-wrap">
    <h2 class="sbc-heading maison-book">{{ section.settings.heading }}</h2>
  </div>

  <div class="sbc-grid" style="--sbc-image-aspect-ratio: {{ section.settings.image_orientation }};">
    {% for block in section.blocks %}
      {% if block.type == 'category' %}
        <a
          href="{{ block.settings.link }}"
          class="sbc-item"
          {{ block.shopify_attributes }}
        >
          <div class="sbc-img-wrap">
            {% if block.settings.image != blank %}
              {{
                block.settings.image
                | image_url: width: 900
                | image_tag: class: 'sbc-img', loading: 'lazy', alt: block.settings.label, widths: '300, 400, 600, 900'
              }}
            {% else %}
              <div class="sbc-img-placeholder">
                {{ 'collection-1' | placeholder_svg_tag: 'sbc-placeholder-svg' }}
              </div>
            {% endif %}
          </div>
          <span class="sbc-label maison-book">{{ block.settings.label }}</span>
        </a>
      {% endif %}
    {% endfor %}
  </div>
</section>

<style>
  .sbc-section {
    background: #fff;
    padding: 56px 0 64px;
    width: 100%;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .sbc-heading-wrap {
    text-align: center;
    margin-bottom: 32px;
    padding: 0 24px;
  }

  .sbc-heading {
    font-size: 3rem;
    font-weight: 400;
    color: #262626;
    letter-spacing: 0.01em;
    margin: 0;
    line-height: 1.3;
  }

  .sbc-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 12px;
    padding: 0 16px;
    max-width: 1440px;
    margin: 0 auto;
    width: 100%;
  }

  .sbc-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 14px;
    text-decoration: none;
    cursor: pointer;
    height: 100%;
  }

  .sbc-img-wrap {
    width: 100%;
    aspect-ratio: var(--sbc-image-aspect-ratio, 2/3);
    overflow: hidden;
    background: #f3f4f6;
    display: block;
    min-height: 0;
  }

  .sbc-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
    transition: transform 0.5s ease;
  }

  .sbc-item:hover .sbc-img {
    transform: scale(1.04);
  }

  .sbc-img-placeholder {
    width: 100%;
    height: 100%;
    background: #e5e7eb;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .sbc-placeholder-svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .sbc-label {
    display: inline-block;
    font-size: 2rem;
    letter-spacing: 1.4px;
    text-transform: uppercase;
    color: #111;
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-thickness: 1px;
    transition: opacity 0.15s;
  }

  .sbc-item:hover .sbc-label {
    opacity: 0.65;
  }

  @media (min-width: 640px) {
    .sbc-grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 12px;
      padding: 0 24px;
    }
  }

  @media (min-width: 1024px) {
    .sbc-section {
      padding: 56px 40px 64px;
      justify-content: center;
    }

    .sbc-grid {
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      gap: 1rem;
      padding: 0 40px;
      align-items: stretch;
      flex: 1;
    }

    .sbc-item {
      width: calc(100% / 5);
      min-width: 140px;
      min-height: min(100vh - 220px, 760px);
      flex-shrink: 0;
    }

    .sbc-img-wrap {
      flex: 1 1 auto;
      height: 100%;
      min-height: 0;
    }

    .sbc-label {
      font-size: 2.625rem;
    }
  }

  @media (min-width: 1280px) {
    .sbc-grid {
      padding: 0 40px;
    }

    .sbc-heading-wrap {
      margin-bottom: 40px;
    }
  }
</style>

{% schema %}
{
  "name": "Shop by Category",
  "tag": "section",
  "class": "shop-by-category-section",
  "max_blocks": 12,
  "limit": 1,
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section Heading",
      "default": "Shop by Category"
    },
    {
      "type": "select",
      "id": "image_orientation",
      "label": "Image orientation",
      "default": "2/3",
      "options": [
        {
          "value": "2/3",
          "label": "Portrait (2:3)"
        },
        {
          "value": "3/4",
          "label": "Portrait tall (3:4)"
        },
        {
          "value": "1/1",
          "label": "Square"
        },
        {
          "value": "4/3",
          "label": "Landscape (4:3)"
        }
      ]
    }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Category",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Category Image"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Category Label",
          "default": "Category"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link URL"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Shop by Category",
      "category": "Everlane",
      "blocks": [
        { "type": "category", "settings": { "label": "Shirts" } },
        { "type": "category", "settings": { "label": "Tees" } },
        { "type": "category", "settings": { "label": "Dress" } },
        { "type": "category", "settings": { "label": "Hoodie" } }
      ]
    }
  ]
}
{% endschema %}
